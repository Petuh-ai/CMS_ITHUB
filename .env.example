# ============================================
# Переменные окружения для Render
# ============================================

# Приложение
APP_DEBUG=false
APP_TIMEZONE=UTC
LOG_LEVEL=info

# База данных (PostgreSQL на Render)
# Значения копируйте из Render Dashboard -> PostgreSQL -> Connection String
DB_DRIVER=pgsql
DB_HOST=your-database-host.render.com
DB_PORT=5432
DB_NAME=cms_bd
DB_USER=cms_user
DB_PASSWORD=your-password

# Сессия
SESSION_SECURE=true
